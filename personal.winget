  # ============================================================
  # Visual Studio Installation
  # Requires module: Microsoft.WinGet.DSC
  # Ships with WinGet. See: https://learn.microsoft.com/windows/package-manager
  # ============================================================
  - name: Install Visual Studio Enterprise Insiders
    type: Microsoft.WinGet.DSC/WinGetPackage
    metadata:
      description: "Install Visual Studio Enterprise Insiders via WinGet DSC"
      module: "Microsoft.WinGet.DSC"
    properties:
      id: "Microsoft.VisualStudio.Enterprise.Insiders"
      source: winget
  # Requires module: Microsoft.VisualStudio.DSC
  # Installed with Visual Studio. See: https://www.powershellgallery.com/packages/Microsoft.VisualStudio.DSC
  - name: VS Insiders Workloads
    type: Microsoft.VisualStudio.DSC/VSComponents
    metadata:
      description: "VS Insiders Workloads"
      winget:
        securityContext: "elevated"
      module: "Microsoft.VisualStudio.DSC"
    dependsOn:
      - "Install Visual Studio Enterprise Insiders"
    properties:
      ProductId: Microsoft.VisualStudio.Product.Enterprise
      ChannelId: VisualStudio.18.Preview
      Components:
        - Microsoft.VisualStudio.Workload.Azure
        - Microsoft.VisualStudio.Workload.CoreEditor
        - Microsoft.VisualStudio.Workload.Data
        - Microsoft.VisualStudio.Workload.ManagedDesktop
        - Microsoft.VisualStudio.Workload.NativeDesktop
        - Microsoft.VisualStudio.Workload.NetCrossPlat
        - Microsoft.VisualStudio.Workload.NetWeb
        - Microsoft.VisualStudio.Workload.Node
      IncludeRecommended: true
  # --- Opt-in: uncomment to install VS Enterprise Release ---
  # - name: Install Visual Studio Enterprise
  #   type: Microsoft.WinGet/Package
  #   metadata:
  #     description: Install Visual Studio Enterprise
  #   properties:
  #     id: "Microsoft.VisualStudio.Enterprise"
