{
  "Common": {
    "Git": {
      "System": {
        "core.longpaths": "true"
      },
      "Global": {
        "credential.helper": "manager"
      }
    },
    "Scoop": {
      "Prereqs": [
        "aria2",
        "7zip",
        "git",
        "innounp",
        "wixtoolset",
        "lessmsi",
        "dark"
      ],
      "Buckets": [
        {
          "name": "main",
          "url": "https://github.com/ScoopInstaller/Main.git"
        },
        {
          "name": "extras",
          "url": "https://github.com/ScoopInstaller/Extras"
        },
        {
          "name": "sysinternals",
          "url": "https://github.com/niheaven/scoop-sysinternals"
        },
        {
          "name": "matracey",
          "url": "https://github.com/matracey/scoop-bucket"
        }
      ],
      "Packages": [
        "main/7zip",
        "main/aria2",
        "main/azure-functions-core-tools",
        "main/cacert",
        "main/chromedriver",
        "main/coreutils",
        "main/curl",
        "main/dark",
        "main/edgedriver",
        "main/ffmpeg",
        "main/geckodriver",
        "main/git",
        "main/grep",
        "main/gsudo",
        "main/innounp",
        "main/lessmsi",
        "main/pester",
        "main/powershell-beautifier",
        "main/scoop-search",
        "main/vim",
        "main/vimtutor",
        "main/wget",
        "main/winget-ps",
        "main/wixtoolset",
        "extras/cru",
        "extras/git-credential-manager",
        "extras/scoop-completion",
        "extras/sysinternals"
      ],
      "Aliases": {
        "upgrade": [
          "scoop update; scoop update *;",
          "Updates Scoop and all installed apps"
        ],
        "reinstall": [
          "scoop uninstall ; scoop install ;",
          "Uninstall and then reinstall an app"
        ],
        "clean": [
          "scoop cleanup *; scoop cache rm *;",
          "Clean up all the caches and remove all the old versions"
        ]
      }
    },
    "VisualStudio": {
