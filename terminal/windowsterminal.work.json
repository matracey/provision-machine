{
  "$help": "https://aka.ms/terminal-documentation",
  "$schema": "https://aka.ms/terminal-profiles-schema-preview",
  "actions": [
    {
      "command": {
        "action": "wt",
        "commandline": "new-tab -p \"SourceVNextAlt\" ; split-pane -p \"SourceVNextAlt\"; split-pane -p \"SourceVNextAlt\"; move-focus left"
      },
      "name": "💻 SourceVNextAlt"
    },
    {
      "command": {
        "action": "wt",
        "commandline": "new-tab -p \"SourceVNext\" ; split-pane -p \"SourceVNext\"; split-pane -p \"SourceVNext\"; move-focus left"
      },
      "name": "💻 SourceVNext"
    },
    {
      "command": {
        "action": "wt",
        "commandline": "new-tab -p \"PCS\" ; split-pane -p \"PCS\"; split-pane -p \"PCS\"; move-focus left"
      },
      "name": "💻 Part Catalog Service (PCS)"
    }
  ],
  "confirmCloseAllTabs": false,
  "keybindings": [
    {
      "id": "Terminal.DuplicatePaneAuto",
      "keys": "alt+shift+d"
    },
    {
      "id": "Terminal.FindText",
      "keys": "ctrl+shift+f"
    },
    {
      "id": "Terminal.FindText",
      "keys": "ctrl+f"
    },
    {
      "id": "Terminal.CopyToClipboard",
      "keys": "ctrl+c"
    },
    {
      "id": "Terminal.PasteFromClipboard",
      "keys": "ctrl+v"
    },
    {
      "id": "Terminal.DuplicateTab",
      "keys": "ctrl+t"
    }
  ],
  "copyFormatting": "none",
  "copyOnSelect": false,
