            value: false
          bool_use_boost_lib:
            value: false
          int_max_mru_size:
            value: 0
        name: "PowerRename"
  - name: Microsoft.PowerToys/RegistryPreviewSettings-0
    type: Microsoft.PowerToys/RegistryPreviewSettings
    metadata:
      description: "Configure PowerToys Registry Preview settings"
      module: "Microsoft.PowerToys"
    dependsOn:
      - Install PowerToys
    properties:
      settings:
        version: "1"
        properties:
          default_reg_app: false
        name: "RegistryPreview"
  - name: Microsoft.PowerToys/ShortcutGuideSettings-0
    type: Microsoft.PowerToys/ShortcutGuideSettings
    metadata:
      description: "Configure PowerToys Shortcut Guide settings"
      module: "Microsoft.PowerToys"
    dependsOn:
      - Install PowerToys
    properties:
      settings:
        version: "1.0"
        properties:
          press_time_for_taskbar_icon_shortcuts:
            value: 900
          DefaultOpenShortcutGuide:
            alt: false
            ctrl: false
            shift: true
            code: 191
            key: ""
            win: true
          open_shortcutguide:
            alt: false
            ctrl: false
            shift: true
            code: 191
            key: ""
            win: true
          overlay_opacity:
            value: 90
          theme:
            value: "system"
          disabled_apps:
            value: ""
          press_time:
            value: 900
          use_legacy_press_win_key_behavior:
            value: false
        name: "Shortcut Guide"
  - name: Microsoft.PowerToys/WorkspacesSettings-0
    type: Microsoft.PowerToys/WorkspacesSettings
    metadata:
      description: "Configure PowerToys Workspaces settings"
      module: "Microsoft.PowerToys"
    dependsOn:
      - Install PowerToys
    properties:
      settings:
        version: "0.0.1"
        properties:
          sortby: 0
          hotkey:
            value:
              alt: false
              ctrl: true
              shift: false
              code: 192
              key: ""
              win: true
        name: "Workspaces"
  - name: Microsoft.PowerToys/ZoomItSettings-0
    type: Microsoft.PowerToys/ZoomItSettings
    metadata:
      description: "Configure PowerToys ZoomIt settings"
      module: "Microsoft.PowerToys"
    dependsOn:
      - Install PowerToys
    properties:
      settings:
        version: "1.0"
        properties: {}
        name: "ZoomIt"
  # ============================================================
  # Visual Studio Installation
  # Requires module: Microsoft.WinGet.DSC
  # Ships with WinGet. See: https://learn.microsoft.com/windows/package-manager
  # ============================================================
  - name: Install Visual Studio Enterprise Insiders
    type: Microsoft.WinGet.DSC/WinGetPackage
    metadata:
      description: "Install Visual Studio Enterprise Insiders via WinGet DSC"
      module: "Microsoft.WinGet.DSC"
    properties:
      id: "Microsoft.VisualStudio.Enterprise.Insiders"
      source: winget
  # Requires module: Microsoft.VisualStudio.DSC
  # Installed with Visual Studio. See: https://www.powershellgallery.com/packages/Microsoft.VisualStudio.DSC
  - name: VS Insiders Workloads
    type: Microsoft.VisualStudio.DSC/VSComponents
    metadata:
      description: "VS Insiders Workloads"
      winget:
        securityContext: "elevated"
      module: "Microsoft.VisualStudio.DSC"
    dependsOn:
      - "Install Visual Studio Enterprise Insiders"
    properties:
      ProductId: Microsoft.VisualStudio.Product.Enterprise
      ChannelId: VisualStudio.18.Preview
      Components:
        - Microsoft.VisualStudio.Workload.Azure
        - Microsoft.VisualStudio.Workload.CoreEditor
        - Microsoft.VisualStudio.Workload.Data
        - Microsoft.VisualStudio.Workload.ManagedDesktop
        - Microsoft.VisualStudio.Workload.NativeDesktop
        - Microsoft.VisualStudio.Workload.NetCrossPlat
        - Microsoft.VisualStudio.Workload.NetWeb
        - Microsoft.VisualStudio.Workload.Node
      IncludeRecommended: true
