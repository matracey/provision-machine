              Value: "%Rex%Grx%Blx"
            Decimal:
              Key: false
              Value: "%Dv"
            CIEXYZ:
              Key: false
              Value: "XYZ(%Xv, %Yv, %Zv)"
            HSB:
              Key: false
              Value: "hsb(%Hu, %Sb%, %Br%)"
