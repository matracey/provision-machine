  # ============================================================
  # Font Repository Cloning
  # Requires module: GitDsc
  # Install with: Install-Module GitDsc
  # ============================================================
  # Workaround: GitDsc/GitClone fails under winget configure because DSCv3
  # expression functions (concat, envvar) are not expanded by the winget
  # processor. Using PowerShellScript until this is fixed upstream.
  # - name: Clone Google Fonts
  #   type: GitDsc/GitClone
  #   metadata:
  #     description: "Clone the Google Fonts repository for local font access"
  #     module: "GitDsc"
  #   properties:
  #     HttpsUrl: https://github.com/google/fonts.git
  #     RootDirectory: "[concat(envvar('USERPROFILE'), '\\fonts')]"
  #     FolderName: google-fonts
  #     ExtraArgs: "--depth 1"
  # - name: Clone Nerd Fonts
  #   type: GitDsc/GitClone
  #   metadata:
  #     description: "Clone the Nerd Fonts repository for developer fonts"
  #     module: "GitDsc"
  #   properties:
  #     HttpsUrl: https://github.com/ryanoasis/nerd-fonts.git
  #     RootDirectory: "[concat(envvar('USERPROFILE'), '\\fonts')]"
  #     FolderName: nerd-fonts
  #     ExtraArgs: "--depth 1"
  - name: Clone Google Fonts
    type: Microsoft.DSC.Transitional/PowerShellScript
    metadata:
      description: "Clone the Google Fonts repository for local font access"
      module: "Microsoft.DSC.Transitional"
    properties:
      testScript: |
        $dir = Join-Path $env:USERPROFILE 'fonts\google-fonts\.git'
        @{ _inDesiredState = (Test-Path $dir) } | ConvertTo-Json
      setScript: |
        $root = Join-Path $env:USERPROFILE 'fonts'
        if (-not (Test-Path $root)) { New-Item -ItemType Directory -Path $root -Force | Out-Null }
        git clone --depth 1 https://github.com/google/fonts.git (Join-Path $root 'google-fonts')
  - name: Clone Nerd Fonts
    type: Microsoft.DSC.Transitional/PowerShellScript
    metadata:
      description: "Clone the Nerd Fonts repository for developer fonts"
      module: "Microsoft.DSC.Transitional"
    properties:
      testScript: |
        $dir = Join-Path $env:USERPROFILE 'fonts\nerd-fonts\.git'
        @{ _inDesiredState = (Test-Path $dir) } | ConvertTo-Json
      setScript: |
        $root = Join-Path $env:USERPROFILE 'fonts'
        if (-not (Test-Path $root)) { New-Item -ItemType Directory -Path $root -Force | Out-Null }
        git clone --depth 1 https://github.com/ryanoasis/nerd-fonts.git (Join-Path $root 'nerd-fonts')
  # ============================================================
  # Font Directory Junctions (FontBase)
  # ============================================================
  - name: Create font junctions for FontBase
    type: Microsoft.DSC.Transitional/PowerShellScript
    metadata:
      description: "Create directory junctions for FontBase font management"
      module: "Microsoft.DSC.Transitional"
    dependsOn:
      - "Clone Google Fonts"
      - "Clone Nerd Fonts"
    properties:
      testScript: |
        $fontBase = Join-Path $env:USERPROFILE "FontBase"
        $googleLink = Join-Path $fontBase "google-fonts"
        $nerdLink = Join-Path $fontBase "nerd-fonts"
        $ok = (Test-Path $googleLink) -and (Test-Path $nerdLink)
        @{ _inDesiredState = $ok } | ConvertTo-Json
      setScript: |
        $fontsDir = Join-Path $env:USERPROFILE "fonts"
        $fontBase = Join-Path $env:USERPROFILE "FontBase"
        if (-not (Test-Path $fontBase)) { New-Item -ItemType Directory -Path $fontBase -Force | Out-Null }
        $googleFontsDir = Join-Path $fontsDir "google-fonts"
        $allDir = Join-Path $googleFontsDir "all"
        if (-not (Test-Path $allDir)) { New-Item -ItemType Directory -Path $allDir -Force | Out-Null }
        foreach ($sub in @("apache", "ofl", "ufl")) {
          $subDir = Join-Path $googleFontsDir $sub
          if (Test-Path $subDir) {
            Get-ChildItem -Path $subDir -Directory | ForEach-Object {
              $target = Join-Path $allDir $_.Name
              if (-not (Test-Path $target)) {
                New-Item -ItemType Junction -Path $allDir -Name $_.Name -Value $_.FullName -Force | Out-Null
              }
            }
          }
        }
        $googleLink = Join-Path $fontBase "google-fonts"
        if (-not (Test-Path $googleLink)) {
          New-Item -ItemType Junction -Path $fontBase -Name "google-fonts" -Value $allDir -Force | Out-Null
        }
        $nerdFontsDir = Join-Path $fontsDir "nerd-fonts"
        $patchedDir = Join-Path $nerdFontsDir "patched-fonts"
        $nerdLink = Join-Path $fontBase "nerd-fonts"
        if (-not (Test-Path $nerdLink)) {
          New-Item -ItemType Junction -Path $fontBase -Name "nerd-fonts" -Value $patchedDir -Force | Out-Null
        }
  # ============================================================
  # Oh My Posh Theme Deployment
  # ============================================================
  - name: Deploy Oh My Posh config
    type: Microsoft.DSC.Transitional/PowerShellScript
    metadata:
      description: "Deploy Oh My Posh prompt theme configuration file"
      module: "Microsoft.DSC.Transitional"
    properties:
      input:
        gistBase: "https://gist.githubusercontent.com/matracey/f4c3a9194cd190a3b3de423aad5dc7e1/raw"
        fileName: "mojada.work.omp.json"
      testScript: |
        $target = Join-Path $env:USERPROFILE '.config\oh-my-posh\mojada.omp.json'
        @{ _inDesiredState = (Test-Path $target) } | ConvertTo-Json
      setScript: |
        param($inputData)
        $target = Join-Path $env:USERPROFILE '.config\oh-my-posh\mojada.omp.json'
        $dir = Split-Path $target
        if (-not (Test-Path $dir)) { New-Item -ItemType Directory -Path $dir -Force | Out-Null }
        $url = "$($inputData.gistBase)/$($inputData.fileName)"
        Invoke-WebRequest -Uri $url -OutFile $target -UseBasicParsing
  # ============================================================
  # Windows Terminal Settings Deployment
  # ============================================================
  - name: Deploy Windows Terminal settings
    type: Microsoft.DSC.Transitional/PowerShellScript
    metadata:
      description: "Deploy Windows Terminal settings JSON for this context"
      module: "Microsoft.DSC.Transitional"
    properties:
      input:
        gistBase: "https://gist.githubusercontent.com/matracey/f4c3a9194cd190a3b3de423aad5dc7e1/raw"
        fileName: "windowsterminal.work.json"
      testScript: |
        $wtPackages = Get-ChildItem "$env:LOCALAPPDATA\Packages\Microsoft.WindowsTerminal*" -Directory -ErrorAction SilentlyContinue
        if (-not $wtPackages) { @{ _inDesiredState = $true } | ConvertTo-Json; return }
        $allPresent = $true
        foreach ($pkg in $wtPackages) {
          $settingsPath = Join-Path $pkg.FullName "LocalState\settings.json"
          if (-not (Test-Path $settingsPath)) { $allPresent = $false; break }
        }
        @{ _inDesiredState = $allPresent } | ConvertTo-Json
      setScript: |
        param($inputData)
        $url = "$($inputData.gistBase)/$($inputData.fileName)"
        $content = (Invoke-WebRequest -Uri $url -UseBasicParsing).Content
        $wtPackages = Get-ChildItem "$env:LOCALAPPDATA\Packages\Microsoft.WindowsTerminal*" -Directory -ErrorAction SilentlyContinue
        foreach ($pkg in $wtPackages) {
          $localState = Join-Path $pkg.FullName "LocalState"
          if (-not (Test-Path $localState)) { New-Item -ItemType Directory -Path $localState -Force | Out-Null }
          $settingsPath = Join-Path $localState "settings.json"
          Set-Content -Path $settingsPath -Value $content -Encoding UTF8 -Force
        }
  # ============================================================
  # Mise Tool Manager
  # ============================================================
  - name: Deploy mise config
    type: Microsoft.DSC.Transitional/PowerShellScript
    metadata:
      description: "Deploy mise configuration for language runtime management"
      module: "Microsoft.DSC.Transitional"
    properties:
      input:
        sourceUrl: "https://gist.githubusercontent.com/matracey/e3febf8a83d05ae2d7ade96fd147cd20/raw/mise.toml"
      testScript: |
        $target = Join-Path $env:USERPROFILE '.config\mise\config.toml'
        @{ _inDesiredState = (Test-Path $target) } | ConvertTo-Json
      setScript: |
        param($inputData)
        $target = Join-Path $env:USERPROFILE '.config\mise\config.toml'
        $dir = Split-Path $target
        if (-not (Test-Path $dir)) { New-Item -ItemType Directory -Path $dir -Force | Out-Null }
        Invoke-WebRequest -Uri $inputData.sourceUrl -OutFile $target -UseBasicParsing
  - name: Run mise install
    type: Microsoft.DSC.Transitional/RunCommandOnSet
    metadata:
      description: "Install language runtimes defined in the mise configuration"
      module: "Microsoft.DSC.Transitional"
    dependsOn:
      - "Deploy mise config"
    properties:
      executable: mise
      arguments:
        - install
  # ============================================================
  # Scoop Package Manager (Hybrid Migration)
  # ============================================================
  - name: Scoop Install and configure
    type: Microsoft.DSC.Transitional/PowerShellScript
    metadata:
      description: "Install Scoop package manager, add buckets, install packages, and configure aliases"
      module: "Microsoft.DSC.Transitional"
    properties:
      input:
        prereqs:
          - 7zip
          - aria2
          - dark
          - git
          - innounp
          - lessmsi
          - wixtoolset
        buckets:
          - name: extras
            url: https://github.com/ScoopInstaller/Extras
          - name: main
            url: https://github.com/ScoopInstaller/Main.git
          - name: matracey
            url: https://github.com/matracey/scoop-bucket
          - name: sysinternals
            url: https://github.com/niheaven/scoop-sysinternals
        packages:
          - extras/cru
          - extras/git-credential-manager
          - extras/scoop-completion
          - extras/sysinternals
          - extras/servicebusexplorer
          - main/7zip
          - main/aria2
          - main/azure-functions-core-tools
          - main/cacert
          - main/chromedriver
          - main/coreutils
          - main/curl
          - main/dark
          - main/edgedriver
          - main/ffmpeg
          - main/geckodriver
          - main/git
          - main/grep
          - main/gsudo
          - main/innounp
          - main/lessmsi
          - main/pester
          - main/powershell-beautifier
          - main/scoop-search
          - main/vim
          - main/vimtutor
          - main/wget
          - main/winget-ps
          - main/wixtoolset
          - matracey/pswindowsupdate
          - matracey/clickpaste
          - matracey/microsoft-graph
          - matracey/microsoft-graph-applications
          - matracey/microsoft-graph-authentication
          - matracey/microsoft-graph-backuprestore
          - matracey/microsoft-graph-bookings
          - matracey/microsoft-graph-calendar
          - matracey/microsoft-graph-changenotifications
          - matracey/microsoft-graph-cloudcommunications
          - matracey/microsoft-graph-compliance
          - matracey/microsoft-graph-crossdeviceexperiences
          - matracey/microsoft-graph-devicemanagement
          - matracey/microsoft-graph-devicemanagement-administration
          - matracey/microsoft-graph-devicemanagement-enrollment
          - matracey/microsoft-graph-devicemanagement-functions
          - matracey/microsoft-graph-devices-cloudprint
          - matracey/microsoft-graph-devices-corporatemanagement
          - matracey/microsoft-graph-devices-serviceannouncement
          - matracey/microsoft-graph-directoryobjects
          - matracey/microsoft-graph-education
          - matracey/microsoft-graph-files
          - matracey/microsoft-graph-groups
          - matracey/microsoft-graph-identity-directorymanagement
          - matracey/microsoft-graph-identity-governance
          - matracey/microsoft-graph-identity-partner
          - matracey/microsoft-graph-identity-signins
          - matracey/microsoft-graph-mail
          - matracey/microsoft-graph-notes
          - matracey/microsoft-graph-people
          - matracey/microsoft-graph-personalcontacts
          - matracey/microsoft-graph-planner
          - matracey/microsoft-graph-reports
          - matracey/microsoft-graph-schemaextensions
          - matracey/microsoft-graph-search
          - matracey/microsoft-graph-security
          - matracey/microsoft-graph-sites
          - matracey/microsoft-graph-teams
          - matracey/microsoft-graph-users
          - matracey/microsoft-graph-users-actions
          - matracey/microsoft-graph-users-functions
          - matracey/setuserfta
        aliases:
          clean: "scoop cleanup *; scoop cache rm *;"
          reinstall: "scoop uninstall ; scoop install ;"
          upgrade: "scoop update; scoop update *;"
      testScript: |
        $scoopCmd = Get-Command scoop -ErrorAction SilentlyContinue
        @{ _inDesiredState = ($null -ne $scoopCmd) } | ConvertTo-Json
      setScript: |
        param($inputData)
        if (-not (Get-Command scoop -ErrorAction SilentlyContinue)) {
          $installer = Join-Path $env:TEMP "install-scoop.ps1"
          Invoke-WebRequest -Uri "https://get.scoop.sh" -OutFile $installer -UseBasicParsing
          & $installer -RunAsAdmin
          Remove-Item $installer -ErrorAction SilentlyContinue
          $env:Path = "$env:USERPROFILE\scoop\shims;$env:Path"
        }
        foreach ($pkg in $inputData.prereqs) { scoop install $pkg }
        foreach ($bucket in $inputData.buckets) {
          scoop bucket add $bucket.name $bucket.url 2>$null
        }
        foreach ($pkg in $inputData.packages) { scoop install $pkg }
        $aliases = $inputData.aliases
        foreach ($name in $aliases.PSObject.Properties.Name) {
          scoop alias add $name $aliases.$name "" 2>$null
        }
